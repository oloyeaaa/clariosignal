---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
---

<PageLayout
  title="About Clario Signal — AI Infrastructure for Local Business Kent"
  description="Clario Signal is a Kent-based AI infrastructure consultancy. We build AI systems for local businesses that make money or save time. Based in Kent, serving the South East."
>
  <!-- Hero -->
  <section class="py-16 md:py-24 border-b border-gray-200">
    <Container size="narrow">
      <h1 class="text-4xl md:text-5xl font-bold text-dark mb-6">
        Built for local businesses in Kent.
      </h1>
      <p class="text-xl text-gray-600 leading-relaxed">
        Clario Signal builds AI systems for local businesses in Kent and the South East. Every system we build either makes you money or saves you time. We prove it within 30 days.
      </p>
    </Container>
  </section>

  <!-- The Problem We Solve -->
  <section class="py-16 md:py-24">
    <Container size="narrow">
      <h2 class="text-2xl font-bold text-dark mb-6">Why local businesses get left behind</h2>

      <div class="prose prose-lg max-w-none text-gray-600 space-y-6">
        <p>
          AI is everywhere in the headlines. But for most local businesses in Kent, nothing has changed. The phone still rings unanswered after 5pm. Admin still takes all evening. Leads still go cold.
        </p>
        <p>
          The vendors selling AI to small businesses either over-promise and under-deliver, or they pitch solutions that solve problems you don't have.
        </p>
        <p>
          Clario Signal works differently. We diagnose first. We only build what the numbers justify. And we measure the result so you know exactly what you got.
        </p>
      </div>
    </Container>
  </section>

  <!-- How We Work -->
  <section class="py-16 md:py-24 border-t border-gray-200">
    <Container size="narrow">
      <h2 class="text-2xl font-bold text-dark mb-6">How we work</h2>

      <div class="prose prose-lg max-w-none text-gray-600 space-y-6">
        <p>
          Every engagement follows The Clarity Loop: Diagnose, Build, Prove.
        </p>
        <p>
          We build it. You operate it. We prove it works.
        </p>
        <p>
          No retainers. No monthly fees. No dependency on us to keep the system running. We build infrastructure that runs without us.
        </p>
      </div>
    </Container>
  </section>

  <!-- The Founder -->
  <section class="py-16 md:py-24 bg-gray-100">
    <Container size="narrow">
      <div class="flex flex-col md:flex-row gap-8 items-start">
        <img
          src="/images/oloye.jpg"
          alt="Oloye Adeosun"
          class="w-32 h-32 rounded-full object-cover flex-shrink-0"
        />
        <div>
          <h2 class="text-2xl font-bold text-dark mb-4">Oloye Adeosun</h2>
          <p class="text-gray-600 mb-4">
            I'm Oloye, founder of Clario Signal. Based in Kent, working with local businesses across the South East.
          </p>
          <p class="text-gray-600 mb-4">
            I started Clario Signal because I saw too many small business owners being sold AI tools they didn't need, by people who had never run a local business.
          </p>
          <p class="text-gray-600">
            The approach here is simple: find the problem that costs you the most time or money, build the system that fixes it, and prove the result in 30 days.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Who We Work With -->
  <section class="py-16 md:py-24">
    <Container size="narrow">
      <h2 class="text-2xl font-bold text-dark mb-8">Who we work with</h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">Trades and Construction</h3>
          <p class="text-gray-600 text-sm">
            Plumbers, electricians, builders, roofers, and landscapers across Kent.
          </p>
        </div>
        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">Hospitality</h3>
          <p class="text-gray-600 text-sm">
            Restaurants, cafes, pubs, hotels, and B&Bs in Kent and the South East.
          </p>
        </div>
        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">Professional Services</h3>
          <p class="text-gray-600 text-sm">
            Accountants, solicitors, estate agents, and architects.
          </p>
        </div>
        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">Health and Beauty</h3>
          <p class="text-gray-600 text-sm">
            Salons, barbershops, clinics, dentists, and gyms.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-dark text-white">
    <Container size="narrow" class="text-center">
      <h2 class="text-3xl font-bold mb-6">Find out what AI can do for your business.</h2>
      <p class="text-gray-300 mb-8">
        The AI Audit maps your biggest opportunity in 90 minutes. £297.
      </p>
      <Button href="/contact" size="lg">
        Book an AI Audit
      </Button>
    </Container>
  </section>
</PageLayout>
