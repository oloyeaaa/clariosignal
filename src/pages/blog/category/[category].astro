---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import PostCard from '@/components/blog/PostCard.astro';
import { CATEGORIES } from '@/lib/constants';
import { getCategoryLabel } from '@/lib/utils';

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { category: cat.slug },
    props: { category: cat.slug, label: cat.label },
  }));
}

const { category, label } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) =>
  !data.draft && data.category === category
);
const posts = allPosts.sort((a, b) =>
  b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<PageLayout
  title={`${label} Articles`}
  description={`Browse all ClarioIQ articles about ${label.toLowerCase()}. Guides, frameworks, and insights for B2B lead generation.`}
>
  <!-- Header -->
  <section class="py-12 border-b border-gray-200">
    <Container>
      <a
        href="/blog"
        class="text-accent hover:text-accent-dark text-sm font-medium mb-4 inline-block"
      >
        &larr; Back to Blog
      </a>
      <h1 class="text-4xl md:text-5xl font-bold text-dark mb-4">
        {label}
      </h1>
      <p class="text-xl text-gray-600">
        {posts.length} article{posts.length !== 1 && 's'}
      </p>
    </Container>
  </section>

  <!-- Post Grid -->
  <section class="py-12">
    <Container>
      {posts.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="text-gray-600 text-center py-12">
          No articles in this category yet. Check back soon.
        </p>
      )}
    </Container>
  </section>
</PageLayout>
