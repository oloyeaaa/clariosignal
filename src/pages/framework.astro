---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import FAQ from '@/components/seo/FAQ.astro';
import SchemaOrg from '@/components/seo/SchemaOrg.astro';

const faqs = [
  {
    question: "What is The Clarity Loop?",
    answer: "The Clarity Loop is a 3-stage framework used by Clario Signal on every engagement: Diagnose (map where time or money is being lost), Build (create the AI system that fixes it), and Prove (measure the result at 30 days). No build starts without a diagnosis."
  },
  {
    question: "What is the AI Audit?",
    answer: "The AI Audit is a 90-minute diagnostic session where we map your business for AI opportunities. You receive a written AI Action Plan with 3-5 prioritised recommendations and ROI estimates. It costs £297 and there is no obligation to proceed further."
  },
  {
    question: "What kinds of AI systems do you build?",
    answer: "Typical builds include AI receptionists that handle enquiries 24/7 via WhatsApp or web chat, automated review request systems, lead follow-up sequences, appointment no-show reduction, customer re-engagement campaigns, and admin automation. Each system is configured and tested before handoff."
  },
  {
    question: "How quickly will I see results?",
    answer: "Most Quick Build systems go live within 7-14 days. We measure results at 30 days against an agreed success metric — either time saved per week or revenue generated. Typical payback period is under 8 weeks."
  },
  {
    question: "Do I need technical knowledge to use the systems?",
    answer: "No. We build it, configure it, test it, and hand it to you working. Every system comes with a plain-English guide and a 60-minute training session. You operate it day-to-day without touching any technology."
  },
];
---

<PageLayout
  title="How It Works — The Clarity Loop"
  description="The Clarity Loop: diagnose, build, prove. See how Clario Signal builds AI infrastructure for local businesses in Kent that delivers measurable results."
>
  <SchemaOrg type="faq" data={{ faqs }} />

  <!-- Hero -->
  <section class="py-16 md:py-24 bg-dark text-white">
    <Container size="narrow">
      <span class="text-accent font-semibold text-sm uppercase tracking-widest">
        How It Works
      </span>
      <h1 class="text-4xl md:text-5xl font-bold mt-4 mb-6">
        The Clarity Loop
      </h1>
      <p class="text-xl text-gray-300 leading-relaxed">
        How we identify, build, and prove AI systems for local businesses.
      </p>
    </Container>
  </section>

  <!-- Core Principle -->
  <section class="py-16 md:py-24 border-b border-gray-200">
    <Container size="narrow">
      <h2 class="text-2xl font-bold text-dark mb-6">The Principle</h2>

      <div class="bg-gray-100 p-8 rounded-lg mb-8">
        <p class="text-2xl font-bold text-dark text-center">
          "Every system makes money or saves time. If it doesn't, we don't build it."
        </p>
      </div>

      <div class="prose prose-lg max-w-none text-gray-600">
        <p>
          Most local businesses have problems that AI can solve today. Missed enquiries. Manual admin. No-show appointments. Leads that go cold.
        </p>
        <p>
          The issue is not the technology. It is knowing which problem to fix first, and proving the result before committing further.
        </p>
        <p>
          The Clarity Loop solves this. We diagnose the specific friction in your business, build the system that fixes it, and measure the outcome at 30 days with real numbers.
        </p>
      </div>
    </Container>
  </section>

  <!-- Stage 1: Diagnose -->
  <section class="py-16 md:py-24 border-b border-gray-200">
    <Container size="narrow">
      <div class="flex items-center gap-4 mb-6">
        <span class="text-5xl font-bold text-gray-200">01</span>
        <h2 class="text-2xl font-bold text-dark">Diagnose</h2>
      </div>

      <p class="text-gray-600 text-lg mb-8">
        We map exactly where your business is losing time or missing revenue. No guesswork. No generic recommendations.
      </p>

      <div class="space-y-6">
        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">Map every manual process</h3>
          <p class="text-gray-600 text-sm">
            We walk through a typical week in your business and identify tasks that repeat on the same pattern.
          </p>
        </div>

        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">Quantify the cost</h3>
          <p class="text-gray-600 text-sm">
            Hours per week multiplied by your hourly rate. Missed enquiries multiplied by average job value. Specific numbers, not estimates.
          </p>
        </div>

        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">Prioritise by ROI</h3>
          <p class="text-gray-600 text-sm">
            We rank every opportunity by the size of the return. The biggest time saving or revenue gain comes first.
          </p>
        </div>
      </div>

      <div class="mt-8 p-6 bg-gray-100 rounded-lg">
        <p class="text-sm text-gray-600">
          <span class="font-semibold text-dark">The AI Audit</span> — a 90-minute diagnostic session. You receive a written AI Action Plan with your top 3 opportunities and ROI estimates. £297. No obligation to proceed.
        </p>
      </div>
    </Container>
  </section>

  <!-- Stage 2: Build -->
  <section class="py-16 md:py-24 border-b border-gray-200">
    <Container size="narrow">
      <div class="flex items-center gap-4 mb-6">
        <span class="text-5xl font-bold text-gray-200">02</span>
        <h2 class="text-2xl font-bold text-dark">Build</h2>
      </div>

      <p class="text-gray-600 text-lg mb-8">
        We build the AI system that fixes it. You don't touch the technology. We configure, test, and hand it to you working.
      </p>

      <div class="space-y-6">
        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">AI Receptionist</h3>
          <p class="text-gray-600 text-sm">
            Handles enquiries 24/7 via WhatsApp or web chat. Captures details, sends instant responses, notifies you.
          </p>
        </div>

        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">Review Generation</h3>
          <p class="text-gray-600 text-sm">
            Automated post-job review requests sent at the right moment. Routes positive reviewers to Google.
          </p>
        </div>

        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">Lead Follow-Up</h3>
          <p class="text-gray-600 text-sm">
            Instant response to new enquiries within 2 minutes, 24/7. Multi-touch follow-up sequence over 7 days.
          </p>
        </div>

        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">No-Show Reduction</h3>
          <p class="text-gray-600 text-sm">
            Automated reminder sequence at 48 hours, 24 hours, and 2 hours before. Cancellations trigger waitlist notifications.
          </p>
        </div>

        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">Customer Re-Engagement</h3>
          <p class="text-gray-600 text-sm">
            AI-powered outreach to dormant customers. Personalised messages based on history. Runs on a recurring schedule without manual input.
          </p>
        </div>
      </div>

      <div class="mt-8 p-6 bg-gray-100 rounded-lg">
        <p class="text-sm text-gray-600">
          Every build includes a plain-English guide, a 60-minute training session, and 30 days of support.
        </p>
      </div>
    </Container>
  </section>

  <!-- Stage 3: Prove -->
  <section class="py-16 md:py-24 border-b border-gray-200">
    <Container size="narrow">
      <div class="flex items-center gap-4 mb-6">
        <span class="text-5xl font-bold text-gray-200">03</span>
        <h2 class="text-2xl font-bold text-dark">Prove</h2>
      </div>

      <p class="text-gray-600 text-lg mb-8">
        We measure the result at 30 days. Time saved. Revenue recovered. Specific numbers.
      </p>

      <div class="space-y-6">
        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">30-Day Results Report</h3>
          <p class="text-gray-600 text-sm">
            Measured against the success metric agreed before the build started. Before and after, in numbers.
          </p>
        </div>

        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-dark mb-2">Next opportunity identified</h3>
          <p class="text-gray-600 text-sm">
            Once the first system is proven, we identify the next highest-priority build. No pressure. Results speak.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- ROI Section -->
  <section class="py-16 md:py-24 bg-gray-100">
    <Container size="narrow">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">What this looks like in numbers</h2>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white p-8 rounded-lg border border-gray-200">
          <h3 class="font-bold text-dark mb-4">Time saved — Restaurant owner</h3>
          <ul class="text-gray-600 text-sm space-y-2">
            <li>8 hours/week on phone enquiries and manual bookings</li>
            <li>Owner time valued at £50/hour = £400/week lost</li>
            <li>AI system cost: £1,497 (one-off)</li>
            <li>Payback period: 3.7 weeks</li>
            <li class="font-semibold text-dark">Annual saving: £20,800</li>
          </ul>
        </div>

        <div class="bg-white p-8 rounded-lg border border-gray-200">
          <h3 class="font-bold text-dark mb-4">Revenue recovered — Plumber</h3>
          <ul class="text-gray-600 text-sm space-y-2">
            <li>40 enquiries/month arriving outside business hours</li>
            <li>Only 8 followed up the next day — most go elsewhere</li>
            <li>AI receptionist responds to all 40 within 2 minutes</li>
            <li>Follow-up rate increases from 20% to 70%</li>
            <li class="font-semibold text-dark">Additional annual revenue: £60,000</li>
          </ul>
        </div>
      </div>
    </Container>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-24">
    <Container size="narrow">
      <FAQ faqs={faqs} title="Common Questions" />
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-dark text-white">
    <Container size="narrow" class="text-center">
      <h2 class="text-3xl font-bold mb-6">Start with a diagnosis.</h2>
      <p class="text-gray-300 mb-8">
        The AI Audit maps your biggest opportunity in 90 minutes. £297.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href="/contact" size="lg">
          Book an AI Audit
        </Button>
      </div>
    </Container>
  </section>
</PageLayout>
