---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import ContactForm from '@/components/ContactForm.astro';
---

<PageLayout
  title="Book an AI Audit | Clario Signal — Kent"
  description="Book a 90-minute AI Audit with Clario Signal. We map where AI can make a difference in your local business. £297. Based in Kent, serving the South East."
>
  <section class="py-16 md:py-24">
    <Container size="narrow">
      <h1 class="text-4xl md:text-5xl font-bold text-dark mb-6">
        Book an AI Audit
      </h1>
      <p class="text-xl text-gray-600 mb-12">
        A 90-minute session that maps where AI can make a difference in your business. Every system we build either makes you money or saves you time. £297.
      </p>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Form -->
        <div>
          <ContactForm />
        </div>

        <!-- Info -->
        <div class="space-y-8">
          <div>
            <h3 class="font-bold text-dark mb-2">Email</h3>
            <a
              href="mailto:hello@clariosignal.com"
              class="text-accent hover:text-accent-dark"
            >
              hello@clariosignal.com
            </a>
          </div>

          <div>
            <h3 class="font-bold text-dark mb-2">What to expect</h3>
            <ul class="text-gray-600 space-y-2">
              <li>You complete a short pre-audit questionnaire (10 minutes)</li>
              <li>We meet for 90 minutes — video call or in person across Kent</li>
              <li>You receive a written AI Action Plan within 48 hours</li>
              <li>No obligation to proceed further</li>
            </ul>
          </div>

          <div>
            <h3 class="font-bold text-dark mb-2">Who this is for</h3>
            <ul class="text-gray-600 space-y-2">
              <li>Local businesses in Kent and the South East</li>
              <li>Business owners who want to understand their AI opportunity before committing to a build</li>
              <li>Anyone who has been burned by tech promises before and wants proof first</li>
            </ul>
          </div>

          <div>
            <h3 class="font-bold text-dark mb-2">Response Time</h3>
            <p class="text-gray-600">
              Typically within 24-48 hours.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </section>
</PageLayout>
