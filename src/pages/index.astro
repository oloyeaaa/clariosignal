---
import PageLayout from '@/layouts/PageLayout.astro';
import Hero from '@/components/home/Hero.astro';
import Framework from '@/components/home/Framework.astro';
import LatestPosts from '@/components/home/LatestPosts.astro';
import CTA from '@/components/home/CTA.astro';
import Container from '@/components/ui/Container.astro';
---

<PageLayout
  title="AI for Local Businesses in Kent"
  description="Clario Signal builds AI systems for local businesses in Kent and the South East. Every system makes you money or saves you time. Proven within 30 days."
>
  <Hero />

  <!-- Problem Section -->
  <section class="py-16 md:py-24">
    <Container size="narrow">
      <h2 class="text-3xl md:text-4xl font-bold text-dark mb-8 text-center">
        Most local businesses are losing time and money to problems that have already been solved.
      </h2>

      <div class="grid md:grid-cols-2 gap-6 mt-8">
        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <p class="text-gray-600">
            Enquiries arriving after hours with no one to answer them.
          </p>
        </div>
        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <p class="text-gray-600">
            Appointment no-shows with no automated reminder in place.
          </p>
        </div>
        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <p class="text-gray-600">
            Manual admin taking 8-12 hours a week that could run automatically.
          </p>
        </div>
        <div class="p-6 bg-white border border-gray-200 rounded-lg">
          <p class="text-gray-600">
            Leads going cold because follow-up takes too long.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- ROI Proof -->
  <section class="py-12 bg-dark text-white">
    <Container>
      <div class="grid md:grid-cols-2 gap-8 text-center">
        <div>
          <p class="text-3xl md:text-4xl font-bold text-accent">£20,800</p>
          <p class="text-gray-300 text-sm mt-2">Annual saving for a restaurant owner who automated phone enquiries and bookings</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-accent">£60,000</p>
          <p class="text-gray-300 text-sm mt-2">Additional annual revenue for a plumber who stopped missing after-hours enquiries</p>
        </div>
      </div>
    </Container>
  </section>

  <Framework />

  <LatestPosts />

  <CTA />
</PageLayout>
