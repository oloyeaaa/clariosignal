---
import { NAV_LINKS } from '@/lib/constants';

const currentPath = Astro.url.pathname;
---

<nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <span class="font-bold text-xl text-dark">ClarioSignal</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium transition-colors duration-200",
              currentPath.startsWith(link.href)
                ? "text-accent"
                : "text-gray-600 hover:text-accent"
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA Button -->
      <div class="hidden md:block">
        <a
          href="/contact"
          class="bg-accent hover:bg-accent-dark text-white font-semibold text-sm px-4 py-2 rounded-md transition-colors duration-200"
        >
          Get Started
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 text-gray-600"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-4 space-y-4">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class="block text-gray-600 hover:text-accent font-medium"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact"
        class="block bg-accent text-white text-center font-semibold py-3 rounded-md"
      >
        Get Started
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
