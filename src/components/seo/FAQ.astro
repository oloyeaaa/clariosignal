---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
  title?: string;
}

const { faqs, title = "Frequently Asked Questions" } = Astro.props;
---

<section class="py-12 border-t border-gray-200">
  <h2 class="text-2xl font-bold text-dark mb-8">{title}</h2>

  <div class="divide-y divide-gray-200">
    {faqs.map((faq) => (
      <div class="py-6">
        <h3 class="text-lg font-semibold text-dark mb-3">
          {faq.question}
        </h3>
        <p class="text-gray-600 leading-relaxed">
          {faq.answer}
        </p>
      </div>
    ))}
  </div>
</section>
