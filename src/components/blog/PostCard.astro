---
import { formatDate, getCategoryLabel } from '@/lib/utils';

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description: string;
      publishDate: Date;
      category: string;
      image?: string;
      imageAlt?: string;
    };
  };
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, publishDate, category, image, imageAlt } = post.data;
---

<article class="group">
  <!-- Image -->
  {image && (
    <a href={`/blog/${post.slug}`} class="block mb-4">
      <div class:list={[
        "overflow-hidden rounded-lg",
        featured ? "aspect-[2/1]" : "aspect-video"
      ]}>
        <img
          src={image}
          alt={imageAlt || title}
          width="800"
          height="450"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </div>
    </a>
  )}

  <!-- Category -->
  <a
    href={`/blog/category/${category}`}
    class="text-xs font-semibold uppercase tracking-widest text-accent hover:text-accent-dark transition-colors"
  >
    {getCategoryLabel(category)}
  </a>

  <!-- Title -->
  <h3 class:list={[
    "font-bold text-dark mt-2 mb-3 group-hover:text-accent transition-colors duration-200",
    featured ? "text-2xl md:text-3xl" : "text-xl"
  ]}>
    <a href={`/blog/${post.slug}`}>
      {title}
    </a>
  </h3>

  <!-- Excerpt -->
  <p class:list={[
    "text-gray-600 leading-relaxed",
    featured ? "text-lg" : "line-clamp-2"
  ]}>
    {description}
  </p>

  <!-- Meta -->
  <div class="flex items-center gap-2 mt-4 text-sm text-gray-500">
    <time datetime={publishDate.toISOString()}>
      {formatDate(publishDate)}
    </time>
  </div>
</article>
