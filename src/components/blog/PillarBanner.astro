---
interface Props {
  pillarTitle: string;
  pillarSlug: string;
}

const { pillarTitle, pillarSlug } = Astro.props;
---

<div class="mb-8 p-4 bg-gray-100 rounded-lg border border-gray-200">
  <p class="text-sm text-gray-600">
    Part of the guide:
    <a
      href={`/blog/${pillarSlug}`}
      class="font-semibold text-accent hover:text-accent-dark transition-colors"
    >
      {pillarTitle} &rarr;
    </a>
  </p>
</div>
