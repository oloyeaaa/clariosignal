---
interface Props {
  sources: {
    title: string;
    url: string;
  }[];
}

const { sources } = Astro.props;
---

{sources.length > 0 && (
  <div class="mt-12 pt-8 border-t border-gray-200">
    <h2 class="text-xl font-bold text-dark mb-4">Sources & Further Reading</h2>
    <ul class="space-y-2">
      {sources.map((source) => (
        <li>
          <a
            href={source.url}
            target="_blank"
            rel="noopener"
            class="text-accent hover:text-accent-dark transition-colors text-sm"
          >
            {source.title}
            <span class="text-gray-400 ml-1">
              &rarr; {new URL(source.url).hostname.replace('www.', '')}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
)}
