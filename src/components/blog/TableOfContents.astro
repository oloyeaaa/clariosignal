---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{filteredHeadings.length > 0 && (
  <nav class="p-6 bg-gray-100 rounded-lg mb-8">
    <h4 class="font-bold text-dark mb-4">Quick Navigation</h4>
    <ul class="space-y-2">
      {filteredHeadings.map((heading) => (
        <li class:list={[heading.depth === 3 && "ml-4"]}>
          <a
            href={`#${heading.slug}`}
            class="text-gray-600 hover:text-accent text-sm transition-colors"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
