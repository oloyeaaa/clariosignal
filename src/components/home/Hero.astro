---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
---

<section class="bg-dark text-white py-20 md:py-32 relative overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-90 to-dark-70 opacity-50"></div>

  <Container class="relative z-10">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
        AI systems for local businesses in Kent.
      </h1>

      <p class="text-lg md:text-xl text-gray-300 mb-8 leading-relaxed">
        We build automation that makes you money or saves you time. Proven within 30 days.
      </p>

      <div class="flex flex-wrap gap-4">
        <Button href="/contact" size="lg">
          Book your free AI Audit call
        </Button>
        <Button href="/framework" variant="ghost" size="lg">
          See how it works
        </Button>
      </div>
    </div>
  </Container>
</section>
