---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';

const stages = [
  {
    number: "01",
    title: "Diagnose",
    description: "We map exactly where your business is losing time or missing revenue. No guesswork. No generic recommendations.",
    color: "border-gray-400",
  },
  {
    number: "02",
    title: "Build",
    description: "We build the AI system that fixes it. You don't touch the technology. We configure, test, and hand it to you working.",
    color: "border-accent/50",
  },
  {
    number: "03",
    title: "Prove",
    description: "We measure the result at 30 days. Time saved. Revenue recovered. Specific numbers.",
    color: "border-accent",
  },
];
---

<section class="py-16 md:py-24 bg-gray-100">
  <Container>
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">
        The Clarity Loop
      </h2>
      <p class="text-gray-600 text-lg">
        Three stages. Every engagement.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-12">
      {stages.map((stage) => (
        <div class:list={[
          "bg-white p-8 rounded-lg border-t-4",
          stage.color
        ]}>
          <span class="text-4xl font-bold text-gray-200">{stage.number}</span>
          <h3 class="text-xl font-bold text-dark mt-4 mb-3">{stage.title}</h3>
          <p class="text-gray-600">{stage.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center">
      <Button href="/contact" size="lg">
        Start with an AI Audit — £297
      </Button>
    </div>
  </Container>
</section>
