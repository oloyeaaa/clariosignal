---
import { getCollection } from 'astro:content';
import Container from '@/components/ui/Container.astro';
import PostCard from '@/components/blog/PostCard.astro';
import Button from '@/components/ui/Button.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = posts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

<section class="py-16 md:py-24">
  <Container>
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-12">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-dark">
          Guides for local business owners
        </h2>
        <p class="text-gray-600 mt-2">
          Practical guides on using AI in your business. No jargon.
        </p>
      </div>
      <Button href="/blog" variant="secondary" size="sm">
        View All
      </Button>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {latestPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </Container>
</section>
