---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
---

<section class="py-16 md:py-24 bg-dark text-white">
  <Container size="narrow" class="text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-6">
      Find out where AI can make a difference in your business.
    </h2>
    <p class="text-gray-300 text-lg mb-8 max-w-xl mx-auto">
      The AI Audit is a 90-minute session that maps your biggest opportunities. £297.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <Button href="/contact" size="lg">
        Book an AI Audit
      </Button>
      <Button href="/framework" variant="ghost" size="lg">
        Learn how it works
      </Button>
    </div>
  </Container>
</section>
