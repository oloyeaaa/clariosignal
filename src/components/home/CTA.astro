---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
---

<section class="py-16 md:py-24 bg-dark text-white">
  <Container size="narrow" class="text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-6">
      Ready to Build Your Signal Stack?
    </h2>
    <p class="text-gray-300 text-lg mb-8 max-w-xl mx-auto">
      Stop sending 1,000 emails hoping for 3 replies. Start targeting 87 prospects who have a bleeding neck problem right now.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <Button href="/contact" size="lg">
        Get Started
      </Button>
      <Button href="/framework" variant="ghost" size="lg">
        Learn the Framework
      </Button>
    </div>
  </Container>
</section>
